<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <link rel="manifest" href="/manifest.json">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>جامعة وادي النيل</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #0a1628;
            --navy-mid: #122040;
            --navy-light: #1a3260;
            --gold: #c9a84c;
            --gold-light: #e8c96a;
            --gold-pale: #f5e6bb;
            --white: #ffffff;
            --off-white: #f8f7f4;
            --text-dark: #1a1a2e;
            --text-mid: #4a5568;
            --text-light: #8892a4;
            --card-bg: #ffffff;
            --bg: #f0f2f7;
            --border: rgba(10,22,40,0.08);
            --shadow-soft: 0 2px 20px rgba(10,22,40,0.08);
            --shadow-med: 0 8px 32px rgba(10,22,40,0.12);
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --nav-h: 68px;
            --header-h: 58px;
        }
        body.dark {
            --bg: #0d1117;
            --card-bg: #161b27;
            --text-dark: #e8eaf0;
            --text-mid: #9aa3b2;
            --text-light: #5c6475;
            --border: rgba(255,255,255,0.07);
            --shadow-soft: 0 2px 20px rgba(0,0,0,0.3);
            --shadow-med: 0 8px 32px rgba(0,0,0,0.4);
            --navy: #1a2840;
            --navy-mid: #1e3050;
            --navy-light: #243a60;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--bg);
            color: var(--text-dark);
            min-height: 100vh;
            transition: background 0.3s, color 0.3s;
        }

        /* ===== SPLASH ===== */
        #splash {
            position: fixed; inset: 0; z-index: 9999;
            background: var(--navy);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            transition: opacity 0.6s ease;
        }
        .splash-ring {
            width: 110px; height: 110px;
            border-radius: 50%;
            border: 3px solid rgba(201,168,76,0.3);
            display: flex; align-items: center; justify-content: center;
            position: relative;
            animation: ringPulse 2s ease-in-out infinite;
        }
        .splash-ring::before {
            content: '';
            position: absolute; inset: -8px;
            border-radius: 50%;
            border: 2px solid rgba(201,168,76,0.15);
        }
        .splash-inner {
            width: 84px; height: 84px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 30px rgba(201,168,76,0.4);
        }
        .splash-inner i { font-size: 36px; color: var(--navy); }
        .splash-title { color: white; font-size: 1.6rem; font-weight: 900; margin-top: 24px; letter-spacing: -0.5px; }
        .splash-sub { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-top: 6px; }
        .splash-dots { display: flex; gap: 8px; margin-top: 32px; }
        .splash-dots span {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--gold); opacity: 0.3;
            animation: dotPulse 1.4s ease-in-out infinite;
        }
        .splash-dots span:nth-child(2) { animation-delay: 0.2s; }
        .splash-dots span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes ringPulse { 0%,100%{transform:scale(1)}50%{transform:scale(1.04)} }
        @keyframes dotPulse { 0%,100%{opacity:0.3}50%{opacity:1} }

        /* ===== APP SHELL ===== */
        .app {
            max-width: 430px;
            margin: 0 auto;
            min-height: 100vh;
            position: relative;
            background: var(--bg);
            box-shadow: 0 0 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        /* ===== HEADER ===== */
        .header {
            height: var(--header-h);
            background: var(--navy);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 18px;
            position: sticky; top: 0; z-index: 100;
        }
        .header-logo { display: flex; align-items: center; gap: 10px; }
        .header-logo-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
        }
        .header-logo-icon i { font-size: 18px; color: var(--navy); }
        .header-title { color: white; font-size: 1rem; font-weight: 700; }
        .header-title span { color: var(--gold); }
        .header-actions { display: flex; gap: 4px; }
        .header-btn {
            width: 36px; height: 36px;
            border-radius: 10px;
            border: none;
            background: rgba(255,255,255,0.1);
            color: white;
            font-size: 0.95rem;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s;
        }
        .header-btn:hover { background: rgba(201,168,76,0.3); color: var(--gold); }

        /* ===== MAIN ===== */
        main {
            padding: 16px 14px;
            padding-bottom: calc(var(--nav-h) + 16px);
            min-height: calc(100vh - var(--header-h));
        }

        .view { display: none; animation: fadeUp 0.35s ease; }
        .view.active { display: block; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ===== HERO BANNER ===== */
        .hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            border-radius: var(--radius-lg);
            padding: 22px 20px;
            margin-bottom: 16px;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: -30px; left: -30px;
            width: 140px; height: 140px;
            border-radius: 50%;
            background: rgba(201,168,76,0.08);
        }
        .hero::after {
            content: '';
            position: absolute;
            bottom: -40px; right: -20px;
            width: 160px; height: 160px;
            border-radius: 50%;
            background: rgba(201,168,76,0.05);
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(201,168,76,0.2);
            color: var(--gold-light);
            font-size: 0.75rem; font-weight: 600;
            padding: 4px 10px; border-radius: 20px;
            margin-bottom: 10px;
        }
        .hero h2 { color: white; font-size: 1.35rem; font-weight: 900; line-height: 1.3; margin-bottom: 6px; }
        .hero p { color: rgba(255,255,255,0.6); font-size: 0.85rem; }
        .hero-actions { display: flex; gap: 8px; margin-top: 16px; }
        .hero-btn {
            flex: 1; padding: 10px;
            border-radius: var(--radius-sm);
            border: none; cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            font-size: 0.85rem; font-weight: 700;
            transition: all 0.2s;
        }
        .hero-btn-primary { background: var(--gold); color: var(--navy); }
        .hero-btn-primary:hover { background: var(--gold-light); }
        .hero-btn-secondary { background: rgba(255,255,255,0.1); color: white; }
        .hero-btn-secondary:hover { background: rgba(255,255,255,0.18); }

        /* ===== QUICK LINKS ===== */
        .quick-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 16px;
        }
        .quick-item {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            padding: 14px 8px;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 8px;
            cursor: pointer;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
            transition: all 0.2s;
        }
        .quick-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-med); }
        .quick-icon {
            width: 42px; height: 42px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
        }
        .q1 { background: rgba(10,22,40,0.07); color: var(--navy); }
        .q2 { background: rgba(201,168,76,0.12); color: #a07820; }
        .q3 { background: rgba(231,76,60,0.1); color: #c0392b; }
        .q4 { background: rgba(39,174,96,0.1); color: #1e8449; }
        body.dark .q1 { background: rgba(201,168,76,0.1); color: var(--gold); }
        .quick-item span { font-size: 0.72rem; font-weight: 600; color: var(--text-mid); text-align: center; }

        /* ===== SECTION HEADER ===== */
        .sec-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 12px;
        }
        .sec-title {
            font-size: 1rem; font-weight: 800;
            color: var(--text-dark);
            display: flex; align-items: center; gap: 8px;
        }
        .sec-title::before {
            content: '';
            display: inline-block;
            width: 4px; height: 18px;
            background: linear-gradient(to bottom, var(--gold), var(--gold-light));
            border-radius: 2px;
        }
        .sec-more {
            font-size: 0.8rem; color: var(--gold);
            font-weight: 700; text-decoration: none; cursor: pointer;
            background: none; border: none; font-family: 'Tajawal', sans-serif;
        }

        /* ===== NEWS SCROLL ===== */
        .news-scroll {
            display: flex; gap: 12px;
            overflow-x: auto; padding-bottom: 8px;
            margin-bottom: 16px;
            scrollbar-width: none;
        }
        .news-scroll::-webkit-scrollbar { display: none; }
        .news-card {
            min-width: 220px; height: 140px;
            border-radius: var(--radius-md);
            overflow: hidden; position: relative; cursor: pointer;
            flex-shrink: 0;
            box-shadow: var(--shadow-med);
        }
        .news-card img { width: 100%; height: 100%; object-fit: cover; }
        .news-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,22,40,0.85) 0%, rgba(10,22,40,0.1) 60%);
            padding: 12px;
            display: flex; flex-direction: column; justify-content: flex-end;
        }
        .news-cat {
            font-size: 0.65rem; font-weight: 700;
            background: var(--gold); color: var(--navy);
            padding: 2px 7px; border-radius: 20px;
            display: inline-block; margin-bottom: 5px;
            width: fit-content;
        }
        .news-card-title { color: white; font-size: 0.82rem; font-weight: 700; line-height: 1.3; }

        /* ===== EVENTS ===== */
        .event-item {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            padding: 14px;
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 10px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
            cursor: pointer;
            transition: all 0.2s;
        }
        .event-item:hover { transform: translateX(-3px); box-shadow: var(--shadow-med); }
        .event-date {
            min-width: 46px;
            background: linear-gradient(135deg, var(--navy), var(--navy-light));
            border-radius: var(--radius-sm);
            padding: 8px 6px;
            text-align: center;
        }
        .event-date .day { color: var(--gold); font-size: 1.3rem; font-weight: 900; line-height: 1; }
        .event-date .month { color: rgba(255,255,255,0.7); font-size: 0.65rem; margin-top: 2px; }
        .event-info h4 { font-size: 0.9rem; font-weight: 700; margin-bottom: 3px; }
        .event-info p { font-size: 0.75rem; color: var(--text-light); display: flex; align-items: center; gap: 5px; }

        /* ===== COLLEGES ===== */
        .colleges-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        .college-card {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            padding: 16px 14px;
            display: flex; align-items: center; gap: 12px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
            cursor: pointer;
            transition: all 0.2s;
        }
        .college-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-med); border-color: var(--gold); }
        .college-icon {
            width: 44px; height: 44px; border-radius: 12px;
            background: linear-gradient(135deg, var(--navy), var(--navy-light));
            display: flex; align-items: center; justify-content: center;
            color: var(--gold); font-size: 1.2rem;
            flex-shrink: 0;
        }
        .college-name { font-size: 0.82rem; font-weight: 700; line-height: 1.3; }

        /* ===== SERVICES ===== */
        .service-card {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 12px;
            box-shadow: var(--shadow-soft);
        }
        .service-item {
            display: flex; align-items: center; gap: 14px;
            padding: 14px 16px;
            cursor: pointer;
            transition: background 0.2s;
            border-bottom: 1px solid var(--border);
        }
        .service-item:last-child { border-bottom: none; }
        .service-item:hover { background: rgba(10,22,40,0.03); }
        body.dark .service-item:hover { background: rgba(255,255,255,0.03); }
        .serv-icon {
            width: 42px; height: 42px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
        }
        .s1 { background: rgba(10,22,40,0.07); color: var(--navy); }
        .s2 { background: rgba(52,152,219,0.1); color: #2980b9; }
        .s3 { background: rgba(155,89,182,0.1); color: #8e44ad; }
        .s4 { background: rgba(39,174,96,0.1); color: #1e8449; }
        .s5 { background: rgba(231,76,60,0.1); color: #c0392b; }
        body.dark .s1 { background: rgba(201,168,76,0.1); color: var(--gold); }
        .serv-text h4 { font-size: 0.92rem; font-weight: 700; }
        .serv-text p { font-size: 0.75rem; color: var(--text-light); margin-top: 2px; }
        .serv-arrow { margin-right: auto; color: var(--text-light); font-size: 0.8rem; }

        /* ===== NEWS FULL LIST ===== */
        .news-full-card {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            overflow: hidden;
            margin-bottom: 12px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
            cursor: pointer;
            transition: all 0.2s;
        }
        .news-full-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-med); }
        .news-full-card img { width: 100%; height: 160px; object-fit: cover; }
        .news-full-body { padding: 14px; }
        .news-full-cat { font-size: 0.72rem; font-weight: 700; color: var(--gold); margin-bottom: 6px; }
        .news-full-title { font-size: 0.95rem; font-weight: 800; margin-bottom: 6px; }
        .news-full-excerpt { font-size: 0.8rem; color: var(--text-light); line-height: 1.5; }
        .news-full-meta { display: flex; align-items: center; gap: 8px; margin-top: 10px; }
        .news-full-meta span { font-size: 0.72rem; color: var(--text-light); display: flex; align-items: center; gap: 4px; }

        /* ===== ABOUT ===== */
        .about-header {
            background: linear-gradient(135deg, var(--navy), var(--navy-light));
            border-radius: var(--radius-lg);
            padding: 24px;
            text-align: center;
            margin-bottom: 14px;
            position: relative; overflow: hidden;
        }
        .about-header::before {
            content: '';
            position: absolute; top: -20px; right: -20px;
            width: 100px; height: 100px; border-radius: 50%;
            background: rgba(201,168,76,0.1);
        }
        .about-logo {
            width: 74px; height: 74px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px;
            box-shadow: 0 8px 24px rgba(201,168,76,0.3);
        }
        .about-logo i { font-size: 32px; color: var(--navy); }
        .about-header h2 { color: white; font-size: 1.3rem; font-weight: 900; }
        .about-header p { color: rgba(255,255,255,0.55); font-size: 0.82rem; margin-top: 4px; }

        .about-stats {
            display: grid; grid-template-columns: repeat(3,1fr);
            gap: 10px; margin-bottom: 14px;
        }
        .stat-box {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            padding: 14px 8px;
            text-align: center;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
        }
        .stat-num { font-size: 1.4rem; font-weight: 900; color: var(--gold); }
        .stat-label { font-size: 0.72rem; color: var(--text-light); margin-top: 2px; }

        .info-card {
            background: var(--card-bg);
            border-radius: var(--radius-md);
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-soft);
        }
        .info-card h3 {
            font-size: 0.95rem; font-weight: 800;
            color: var(--navy); margin-bottom: 10px;
            padding-bottom: 8px; border-bottom: 2px solid var(--gold-pale);
            display: flex; align-items: center; gap: 8px;
        }
        body.dark .info-card h3 { color: var(--gold); border-color: rgba(201,168,76,0.2); }
        .info-card h3 i { color: var(--gold); }
        .info-card p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.7; font-style: italic; }

        .ext-link {
            display: flex; align-items: center; justify-content: space-between;
            padding: 12px 14px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--border);
            margin-bottom: 10px;
            cursor: pointer; text-decoration: none;
            background: var(--card-bg);
            transition: all 0.2s;
        }
        .ext-link:hover { border-color: var(--gold); }
        .ext-link span { font-size: 0.88rem; font-weight: 700; color: var(--text-dark); display: flex; align-items: center; gap: 8px; }
        .ext-link i.fa-arrow-left { color: var(--text-light); font-size: 0.8rem; }

        /* ===== BOTTOM NAV ===== */
        .bottom-nav {
            position: fixed; bottom: 0;
            left: 50%; transform: translateX(-50%);
            width: 100%; max-width: 430px;
            height: var(--nav-h);
            background: var(--card-bg);
            display: flex; justify-content: space-around; align-items: center;
            border-top: 1px solid var(--border);
            box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
            z-index: 100;
            padding: 0 6px;
        }
        .nav-btn {
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 4px; flex: 1; height: 100%;
            background: none; border: none; cursor: pointer;
            color: var(--text-light);
            font-family: 'Tajawal', sans-serif;
            transition: all 0.2s;
            border-radius: 12px;
            position: relative;
        }
        .nav-btn i { font-size: 1.15rem; transition: all 0.2s; }
        .nav-btn span { font-size: 0.68rem; font-weight: 600; }
        .nav-btn.active { color: var(--navy); }
        body.dark .nav-btn.active { color: var(--gold); }
        .nav-btn.active i { color: var(--gold); transform: translateY(-2px); }
        .nav-btn.active::after {
            content: '';
            position: absolute; bottom: 6px;
            width: 4px; height: 4px; border-radius: 50%;
            background: var(--gold);
        }

        /* ===== TOAST ===== */
        #toast {
            position: fixed;
            bottom: calc(var(--nav-h) + 12px);
            left: 50%; transform: translateX(-50%) translateY(20px);
            background: var(--navy);
            color: white;
            padding: 12px 20px;
            border-radius: 50px;
            font-size: 0.85rem; font-weight: 600;
            z-index: 9998;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            border: 1px solid rgba(201,168,76,0.3);
            white-space: nowrap;
            max-width: 90%;
        }
        #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

        /* ===== PAGE TITLE BAR ===== */
        .page-title-bar {
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 16px;
        }
        .page-title-bar h2 { font-size: 1.2rem; font-weight: 900; }
        .page-title-bar .count {
            background: var(--gold); color: var(--navy);
            font-size: 0.7rem; font-weight: 800;
            padding: 2px 8px; border-radius: 20px;
        }

        /* ===== SEARCH BAR ===== */
        .search-bar {
            display: flex; align-items: center; gap: 10px;
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: var(--radius-md);
            padding: 10px 14px;
            margin-bottom: 16px;
            box-shadow: var(--shadow-soft);
        }
        .search-bar i { color: var(--text-light); }
        .search-bar input {
            flex: 1; border: none; background: none;
            font-family: 'Tajawal', sans-serif;
            font-size: 0.9rem; color: var(--text-dark);
            outline: none;
        }
        .search-bar input::placeholder { color: var(--text-light); }
    </style>
</head>
<body>

<!-- Splash Screen -->
<div id="splash">
    <div class="splash-ring">
        <div class="splash-inner"><i class="fa-solid fa-graduation-cap"></i></div>
    </div>
    <div class="splash-title">جامعة وادي النيل</div>
    <div class="splash-sub">Nile Valley University</div>
    <div class="splash-dots">
        <span></span><span></span><span></span>
    </div>
</div>

<!-- App -->
<div class="app">

    <!-- Header -->
    <header class="header">
        <div class="header-logo">
            <div class="header-logo-icon"><i class="fa-solid fa-graduation-cap"></i></div>
            <div class="header-title">وادي <span>النيل</span></div>
        </div>
        <div class="header-actions">
